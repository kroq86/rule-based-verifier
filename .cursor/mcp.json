{
  "mcpServers": {
    "rule-based-verifier": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "exec bash \"$CURSOR_WORKSPACE_FOLDER/mcp/scripts/run-docker-mcp.sh\""
      ],
      "env": {
        "RULE_BASED_DOCKER_IMAGE": "rule-based-verifier:local",
        "CURSOR_WORKSPACE_FOLDER": "${workspaceFolder}",
        "VSCODE_WORKSPACE_FOLDER": "${workspaceFolder}"
      }
    }
  }
}
